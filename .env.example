# ============================================================
# Small Group Tracker — Environment Variables
# ============================================================
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control.
# ============================================================

# ----- Server -----------------------------------------------

# Express session secret — change this to a long random string in production
# Generate one with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
SESSION_SECRET=change-me-to-a-long-random-string

# Port the dev/prod server listens on (default: 5000)
PORT=5000

# Node environment: "development" or "production"
NODE_ENV=development

# ----- Database ---------------------------------------------
# The app uses SQLite by default (no config needed for local dev).
# The database file is created automatically at:
#   ./data/small-group-tracker.db  (production)
#   ./small-group-tracker.db       (development)
#
# If you migrate to Supabase Postgres, set these instead and
# update server/storage.ts to use the postgres driver:

# SUPABASE_URL=https://your-project.supabase.co
# SUPABASE_ANON_KEY=your-anon-key
# SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
# DATABASE_URL=postgresql://postgres:password@db.your-project.supabase.co:5432/postgres

# ----- Admin Seed -------------------------------------------
# The default admin account created on first startup.
# Change these before deploying to production.
# After first run the seed is skipped if the admin already exists.

SEED_ADMIN_EMAIL=admin@example.com
SEED_ADMIN_PASSWORD=Admin1234!
SEED_ADMIN_FIRST_NAME=App
SEED_ADMIN_LAST_NAME=Admin
