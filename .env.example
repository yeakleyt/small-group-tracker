# ============================================================
# Small Group Tracker — Environment Variables
# ============================================================
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control.
# ============================================================

# ----- Server -----------------------------------------------

# Express session secret — change this to a long random string in production
# Generate one with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
SESSION_SECRET=change-me-to-a-long-random-string

# Port the dev/prod server listens on (default: 5000)
PORT=5000

# Node environment: "development" or "production"
NODE_ENV=development

# ----- Database ---------------------------------------------
# The app uses SQLite by default (no config needed for local dev).
# The database file is created automatically at:
#   ./data/small-group-tracker.db  (production)
#   ./small-group-tracker.db       (development)
#
# If you migrate to Supabase Postgres, set these instead and
# update server/storage.ts to use the postgres driver:

# SUPABASE_URL=https://your-project.supabase.co
# SUPABASE_ANON_KEY=your-anon-key
# SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
# DATABASE_URL=postgresql://postgres:password@db.your-project.supabase.co:5432/postgres

# ----- Push Notifications (optional) -----------------------
# Generate VAPID keys by running this command once locally:
#   npx web-push generate-vapid-keys
# Then paste the output values below. Never regenerate these — it will
# invalidate all existing subscriptions.

# VAPID_PUBLIC_KEY=your-public-key-here
# VAPID_PRIVATE_KEY=your-private-key-here
# VAPID_EMAIL=mailto:you@yourdomain.com

# ----- Email Reminders (optional) --------------------------
# Sign up free at https://resend.com — free tier is 3,000 emails/month.
# If RESEND_API_KEY is not set, the reminder scheduler is disabled entirely.

# RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxx
# RESEND_FROM=Small Group Manager <no-reply@yourdomain.com>
# APP_URL=https://small-group-manager.onrender.com

# Hour (0-23) to send daily reminders, server time (default: 8 = 8am)
# REMINDER_HOUR=8

# ----- Admin Seed -------------------------------------------
# The default admin account created on first startup.
# Change these before deploying to production.
# After first run the seed is skipped if the admin already exists.

SEED_ADMIN_EMAIL=admin@example.com
SEED_ADMIN_PASSWORD=Admin1234!
SEED_ADMIN_FIRST_NAME=App
SEED_ADMIN_LAST_NAME=Admin
